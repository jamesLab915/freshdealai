# PostgreSQL (Prisma 7 + adapter). Omit to use rich mock deals in dev/preview.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flashdeal"

# Public site URL — canonical, OG, sitemap, robots. Recommended in production.
# Local: optional; if unset, dev defaults to http://localhost:3010 (see npm run dev:3010).
# Vercel: if unset, the app uses VERCEL_URL until you set this to your custom domain.
NEXT_PUBLIC_SITE_URL="http://localhost:3010"

# Admin — HTTP Basic Auth for /admin/* and /api/admin/* (middleware)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-in-production"

# OpenAI — Responses API + structured JSON (see src/lib/openai/responses.ts)
OPENAI_API_KEY="sk-..."

# Optional model overrides
# OPENAI_MODEL_FAST="gpt-4o-mini"
# OPENAI_MODEL_QUALITY="gpt-4o"

# Amazon Product Advertising API (optional — ingestion shows “ready” when set)
# AMAZON_ACCESS_KEY_ID=""
# AMAZON_SECRET_ACCESS_KEY=""
# Or legacy-style keys if you use them in your stack:
# AMAZON_PA_API_KEY=""
# PA_API_ACCESS_KEY=""

# Affiliate monetization (appended before /out redirects)
AMAZON_ASSOCIATE_TAG="yourtag-20"
# Optional: Walmart — "paramName=value" for your program
# WALMART_AFFILIATE_PARAM=""

# Vercel Cron — protect /api/cron/run (Authorization: Bearer …) or rely on x-vercel-cron
CRON_SECRET="generate-a-long-random-string"
